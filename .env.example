# BANCO DE DADOS (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:sua_senha@seu_host:5432/postgres?schema=public"

# WHATSAPP CLOUD API DA META (Opcional - Legado)
META_WA_ACCESS_TOKEN="seu_access_token_aqui"
META_WA_PHONE_NUMBER_ID="seu_phone_number_id_aqui"
META_WA_BUSINESS_ACCOUNT_ID="seu_business_account_id_aqui"
META_WA_VERIFY_TOKEN="seu_token_de_verificacao_do_webhook"

# TWILIO WHATSAPP API
TWILIO_ACCOUNT_SID="seu_account_sid_aqui"
TWILIO_AUTH_TOKEN="seu_auth_token_aqui"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886" # Substitua pelo seu número do Twilio (ex: sandbox)


# PUSHER (Comunicação em tempo real compatível com Vercel)
PUSHER_APP_ID="seu_pusher_app_id"
PUSHER_KEY="sua_pusher_key"
PUSHER_SECRET="seu_pusher_secret"
PUSHER_CLUSTER="seu_pusher_cluster"

NEXT_PUBLIC_PUSHER_KEY="sua_pusher_key"
NEXT_PUBLIC_PUSHER_CLUSTER="seu_pusher_cluster"

# SEGURANÇA E AMBIENTE
NEXTAUTH_SECRET="uma_chave_secreta_longa"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
